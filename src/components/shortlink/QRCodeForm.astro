---
---

<div class="w-full max-w-xl" id="qrcode-app">
  <div class="space-y-3" id="form-section">
    <div class="flex gap-2">
      <div class="relative flex-1">
        <input
          type="text"
          id="qr-input"
          placeholder="Enter URL or text to generate QR Code"
          class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-4 py-3 text-sm text-neutral-100 placeholder:text-neutral-600 focus:outline-none focus:border-violet-500 transition-colors"
        />
      </div>

      <button
        id="generate-btn"
        class="px-6 py-3 bg-violet-600 hover:bg-violet-500 active:scale-95 text-white text-sm font-medium rounded-lg transition-all disabled:opacity-50 disabled:cursor-not-allowed shrink-0"
      >
        Generate
      </button>
    </div>

    <p id="error-msg" class="text-xs text-red-400 hidden"></p>
  </div>

  <div
    id="result-section"
    class="hidden mt-4 bg-neutral-900 border border-violet-500/40 rounded-lg p-6 flex flex-col items-center justify-center gap-4"
  >
    <p class="text-xs text-neutral-500 self-start">Your QR Code is ready</p>
    
    <div class="p-3 bg-white rounded-xl shadow-lg shadow-violet-500/5">
      <img
        id="qr-image"
        src=""
        alt="Generated QR Code"
        class="w-48 h-48 block"
        crossorigin="anonymous"
      />
    </div>

    <div class="flex items-center gap-2 w-full justify-center">
      <button
        id="download-btn"
        class="flex items-center gap-1.5 text-xs px-4 py-2 rounded-md bg-neutral-800 hover:bg-neutral-700 text-neutral-300 transition-colors font-medium"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        Download PNG
      </button>
      <button
        id="new-btn"
        class="text-xs px-4 py-2 rounded-md bg-neutral-800 hover:bg-neutral-700 text-neutral-400 transition-colors"
      >
        + New
      </button>
    </div>
  </div>

  <div id="history-section" class="mt-8 hidden">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-xs font-medium text-neutral-500 uppercase tracking-wider">
        Recent QR Codes
      </h3>
      <button
        id="clear-history-btn"
        class="text-xs text-neutral-600 hover:text-red-400 transition-colors"
      >
        Clear all
      </button>
    </div>
    <div id="history-list" class="grid grid-cols-1 sm:grid-cols-2 gap-2"></div>
  </div>
</div>

<script>
  const STORAGE_KEY = "crotools_qrcodes";

  interface QRCodeItem {
    id: string;
    text: string;
    qrUrl: string;
    createdAt: number;
  }

  // ---- Helpers ----
  function getQRs(): Array<QRCodeItem> {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
    } catch {
      return [];
    }
  }

  function saveQR(id: string, text: string, qrUrl: string) {
    const items = getQRs();
    const filtered = items.filter((item) => item.text !== text);
    filtered.unshift({ id, text, qrUrl, createdAt: Date.now() });

    localStorage.setItem(STORAGE_KEY, JSON.stringify(filtered.slice(0, 10))); // Simpan 10 riwayat terakhir
  }

  function showError(msg: string) {
    const el = document.getElementById("error-msg")!;
    el.textContent = msg;
    el.classList.remove("hidden");
    setTimeout(() => el.classList.add("hidden"), 3000);
  }

  function renderHistory() {
    const items = getQRs();
    const section = document.getElementById("history-section")!;
    const list = document.getElementById("history-list")!;

    if (items.length === 0) {
      section.classList.add("hidden");
      return;
    }

    section.classList.remove("hidden");
    list.innerHTML = items
      .map(
        (item) => `
        <div class="flex items-center gap-3 bg-neutral-900 border border-neutral-800 rounded-lg p-2.5 group relative">
          <img src="${item.qrUrl}&size=60x60" class="w-12 h-12 bg-white p-0.5 rounded shrink-0" alt="Minified QR" />
          <div class="min-w-0 flex-1">
            <p class="text-xs text-neutral-300 font-mono truncate pr-6">${item.text}</p>
            <p class="text-[10px] text-neutral-600 mt-0.5">${new Date(item.createdAt).toLocaleDateString()}</p>
          </div>
          <button
            class="load-hist-btn absolute inset-0 w-full h-full cursor-pointer opacity-0"
            data-text="${encodeURIComponent(item.text)}"
            data-qr="${encodeURIComponent(item.qrUrl)}"
          ></button>
        </div>
      `,
      )
      .join("");

    // Bind event ketika item history diklik untuk dimuat kembali ke layar utama
    list.querySelectorAll<HTMLButtonElement>(".load-hist-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const text = decodeURIComponent(btn.dataset.text!);
        const qrUrl = decodeURIComponent(btn.dataset.qr!);
        
        urlInput.value = text;
        qrImage.src = qrUrl;
        resultSection.classList.remove("hidden");
      });
    });
  }

  // ---- Main Logic ----
  const urlInput = document.getElementById("qr-input") as HTMLInputElement;
  const generateBtn = document.getElementById("generate-btn") as HTMLButtonElement;
  const resultSection = document.getElementById("result-section")!;
  const qrImage = document.getElementById("qr-image") as HTMLImageElement;
  const downloadBtn = document.getElementById("download-btn") as HTMLButtonElement;
  const newBtn = document.getElementById("new-btn")!;
  const clearBtn = document.getElementById("clear-history-btn")!;

  generateBtn.addEventListener("click", () => {
    const text = urlInput.value.trim();

    if (!text) {
      showError("Please enter some text or a URL.");
      return;
    }

    generateBtn.disabled = true;
    generateBtn.textContent = "...";

    // Menggunakan API Publik goqr.me (Ukuran default hasil generate 300x300 px)
    const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(text)}`;
    
    qrImage.src = qrUrl;

    // Tunggu gambar ter-load sempurna di browser sebelum membuka loading state tombol
    qrImage.onload = () => {
      generateBtn.disabled = false;
      generateBtn.textContent = "Generate";
      resultSection.classList.remove("hidden");
      
      const id = Math.random().toString(36).substring(2, 8);
      saveQR(id, text, qrUrl);
      renderHistory();
    };

    qrImage.onerror = () => {
      generateBtn.disabled = false;
      generateBtn.textContent = "Generate";
      showError("Failed to generate QR Code. Try again.");
    };
  });

  // Fungsi untuk mendownload gambar QR Code secara langsung (.png)
  downloadBtn.addEventListener("click", async () => {
    try {
      const response = await fetch(qrImage.src);
      const blob = await response.blob();
      const blobUrl = URL.createObjectURL(blob);
      
      const a = document.createElement("a");
      a.href = blobUrl;
      a.download = `crotools-qr-${Date.now()}.png`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(blobUrl);
    } catch {
      showError("Failed to download image. Try right-clicking the QR Code instead.");
    }
  });

  newBtn.addEventListener("click", () => {
    urlInput.value = "";
    resultSection.classList.add("hidden");
    urlInput.focus();
  });

  clearBtn.addEventListener("click", () => {
    localStorage.removeItem(STORAGE_KEY);
    renderHistory();
  });

  // Init
  renderHistory();
</script>