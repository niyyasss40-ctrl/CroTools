---

---

<div class="w-full max-w-xl" id="shortlink-app">
  <div class="space-y-3" id="form-section">
    <div class="relative">
      <input
        type="url"
        id="url-input"
        placeholder="https://your-long-url.com/paste-here"
        class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-4 py-3 text-sm text-neutral-100 placeholder:text-neutral-600 focus:outline-none focus:border-violet-500 transition-colors"
      />
    </div>

    <div class="flex gap-2">
      <div class="relative flex-1">
        <select
          id="domain-select"
          class="w-full bg-neutral-900 border border-neutral-700 rounded-lg px-3 py-3 text-sm text-neutral-100 focus:outline-none focus:border-violet-500 transition-colors font-mono appearance-none cursor-pointer"
        >
          <option value="cro.to">cro.to</option>
          <option value="cleanuri.com">cleanuri.com</option>
          <option value="is.gd">is.gd</option>
          <option value="tinyurl.com">tinyurl.com</option>
        </select>
        <div
          class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-neutral-500"
        >
          <svg
            class="fill-current h-4 w-4"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
          >
            <path
              d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"
            ></path>
          </svg>
        </div>
      </div>

      <button
        id="shorten-btn"
        class="px-6 py-3 bg-violet-600 hover:bg-violet-500 active:scale-95 text-white text-sm font-medium rounded-lg transition-all disabled:opacity-50 disabled:cursor-not-allowed shrink-0"
      >
        Shorten
      </button>
    </div>

    <p id="error-msg" class="text-xs text-red-400 hidden"></p>
  </div>

  <div
    id="result-section"
    class="hidden mt-4 bg-neutral-900 border border-violet-500/40 rounded-lg p-4"
  >
    <p class="text-xs text-neutral-500 mb-2">Your short link is ready</p>
    <div class="flex items-center justify-between gap-3">
      <a
        id="result-link"
        href="#"
        target="_blank"
        class="font-mono text-violet-300 text-sm hover:text-violet-200 transition-colors truncate"
      >
      </a>
      <div class="flex items-center gap-2 shrink-0">
        <button
          id="copy-btn"
          class="flex items-center gap-1.5 text-xs px-3 py-1.5 rounded-md bg-neutral-800 hover:bg-neutral-700 text-neutral-300 transition-colors"
        >
          <svg
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <rect x="9" y="9" width="13" height="13" rx="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
            ></path>
          </svg>
          <span id="copy-label">Copy</span>
        </button>
        <button
          id="new-btn"
          class="text-xs px-3 py-1.5 rounded-md bg-neutral-800 hover:bg-neutral-700 text-neutral-300 transition-colors"
        >
          + New
        </button>
      </div>
    </div>
  </div>

  <div id="history-section" class="mt-8 hidden">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-xs font-medium text-neutral-500 uppercase tracking-wider">
        Recent links
      </h3>
      <button
        id="clear-history-btn"
        class="text-xs text-neutral-600 hover:text-red-400 transition-colors"
      >
        Clear all
      </button>
    </div>
    <div id="history-list" class="space-y-2"></div>
  </div>
</div>

<script>
  import { actions } from "astro:actions";

  const STORAGE_KEY = "crotools_links";

  interface ShortLink {
    slug: string;
    domain: string;
    url: string;
    shortUrl: string;
    createdAt: number;
  }

  // ---- Helpers ----
  function generateSlug(length = 6): string {
    const chars = "abcdefghijklmnopqrstuvwxyz0123456789";
    return Array.from(
      { length },
      () => chars[Math.floor(Math.random() * chars.length)],
    ).join("");
  }

  function getLinks(): Array<ShortLink> {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
    } catch {
      return [];
    }
  }

  function saveLink(
    slug: string,
    domain: string,
    url: string,
    shortUrl: string,
  ) {
    const links = getLinks();
    // Gunakan shortUrl sebagai identifier unik agar tidak bentrok antar domain
    const filtered = links.filter((l) => l.shortUrl !== shortUrl);
    filtered.unshift({ slug, domain, url, shortUrl, createdAt: Date.now() });

    // Simpan maksimal 20 history
    localStorage.setItem(STORAGE_KEY, JSON.stringify(filtered.slice(0, 20)));
  }

  function showError(msg: string) {
    const el = document.getElementById("error-msg")!;
    el.textContent = msg;
    el.classList.remove("hidden");
    setTimeout(() => el.classList.add("hidden"), 3000);
  }

  function renderHistory() {
    const links = getLinks();
    const section = document.getElementById("history-section")!;
    const list = document.getElementById("history-list")!;

    if (links.length === 0) {
      section.classList.add("hidden");
      return;
    }

    section.classList.remove("hidden");
    list.innerHTML = links
      .map(
        (l) => `
        <div class="flex items-center justify-between gap-3 bg-neutral-900 rounded-lg px-3 py-2.5 group">
          <div class="min-w-0 flex-1">
            <a
              href="${l.shortUrl}"
              target="_blank"
              class="font-mono text-xs text-violet-400 hover:text-violet-300 transition-colors truncate block"
            >
              ${l.shortUrl.replace("https://", "")}
            </a>
            <p class="text-xs text-neutral-600 truncate mt-0.5">${l.url}</p>
          </div>
          <button
            class="copy-hist-btn shrink-0 text-xs text-neutral-600 hover:text-neutral-300 transition-colors opacity-0 group-hover:opacity-100"
            data-short="${l.shortUrl}"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
          </button>
        </div>
      `,
      )
      .join("");

    // Bind event klik untuk copy button di history
    list
      .querySelectorAll<HTMLButtonElement>(".copy-hist-btn")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const url = btn.dataset.short!;
          navigator.clipboard.writeText(url);
          btn.innerHTML = `<span class="text-green-400 text-xs">✓</span>`;
          setTimeout(() => {
            btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
          }, 1500);
        });
      });
  }

  // ---- Main Logic ----
  const urlInput = document.getElementById("url-input") as HTMLInputElement;
  const domainSelect = document.getElementById(
    "domain-select",
  ) as HTMLSelectElement;
  const shortenBtn = document.getElementById(
    "shorten-btn",
  ) as HTMLButtonElement;
  const resultSection = document.getElementById("result-section")!;
  const resultLink = document.getElementById(
    "result-link",
  ) as HTMLAnchorElement;
  const copyBtn = document.getElementById("copy-btn")!;
  const copyLabel = document.getElementById("copy-label")!;
  const newBtn = document.getElementById("new-btn")!;
  const clearBtn = document.getElementById("clear-history-btn")!;

  shortenBtn.addEventListener("click", async () => {
    const url = urlInput.value.trim();
    const selectedDomain = domainSelect.value;

    if (!url) {
      showError("Please enter a URL.");
      return;
    }

    try {
      new URL(url);
    } catch {
      showError("That doesn't look like a valid URL.");
      return;
    }

    // Set status tombol loading
    shortenBtn.disabled = true;
    shortenBtn.textContent = "...";

    const slug = generateSlug();
    let shortUrl = "";

    // Simulasi integrasi jembatan API luar sesuai pilihan dropdown
    if (selectedDomain === "cro.to") {
      // Mock internal domain bawaan website kamu
      shortUrl = `${window.location.origin}/s/${slug}`;
    } else if (selectedDomain === "cleanuri.com") {
      const { data, error } = await actions.shorten({ url: url });

      if (error || !data?.success) {
        showError(error?.message || data?.error || "API Error.");
        shortenBtn.disabled = false;
        shortenBtn.textContent = "Shorten";
        return;
      }

      shortUrl = data.result_url;
    } else {
      // Fallback fallback untuk is.gd / tinyurl (Atau nanti tinggal sesuaikan fetch API-nya di sini)
      shortUrl = `https://${selectedDomain}/${slug}`;
    }

    // Kembalikan state tombol
    shortenBtn.disabled = false;
    shortenBtn.textContent = "Shorten";

    // Simpan ke localStorage dengan skema baru
    saveLink(slug, selectedDomain, url, shortUrl);

    // Tampilkan Hasil
    resultLink.href = shortUrl;
    resultLink.textContent = shortUrl
      .replace("https://", "")
      .replace("http://", "");
    resultSection.classList.remove("hidden");

    renderHistory();
  });

  copyBtn.addEventListener("click", () => {
    const url = resultLink.href;
    navigator.clipboard.writeText(url);
    copyLabel.textContent = "Copied!";
    copyBtn.classList.add("text-green-400");
    setTimeout(() => {
      copyLabel.textContent = "Copy";
      copyBtn.classList.remove("text-green-400");
    }, 2000);
  });

  newBtn.addEventListener("click", () => {
    urlInput.value = "";
    resultSection.classList.add("hidden");
    urlInput.focus();
  });

  clearBtn.addEventListener("click", () => {
    localStorage.removeItem(STORAGE_KEY);
    renderHistory();
  });

  // Jalankan render history saat pertama kali load halaman
  renderHistory();
</script>
