---
import Icon from "../assets/images/crotools.png";

const tools = [
  { label: "Short Link", href: "/shortlink", icon: "🔗" },
  { label: "QR Code", href: "/qrcode", icon: "▦" },
  { label: "YT to MP3", href: "/yt-mp3", icon: "▶", soon: true },
  { label: "TikTok DL", href: "/tiktok", icon: "♪", soon: true },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-neutral-800 bg-neutral-950/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-7 h-7 rounded-md bg-violet-500 flex items-center justify-center text-white text-xs font-bold">
        <img src={Icon.src} alt="CroTools Logo" />
      </div>
      <span class="font-semibold text-sm tracking-tight">
        cro<span class="text-violet-400">tools</span>
      </span>
    </a>

    <!-- Nav links -->
    <nav class="hidden md:flex items-center gap-1">
      {
        tools.map((tool) => (
          <a
            href={tool.soon ? "#" : tool.href}
            class:list={[
              "relative flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm transition-colors",
              currentPath.startsWith(tool.href) && !tool.soon
                ? "bg-violet-500/15 text-violet-300"
                : "text-neutral-400 hover:text-neutral-100 hover:bg-neutral-800",
              tool.soon ? "cursor-default opacity-50" : "",
            ]}
          >
            <span class="text-xs">{tool.icon}</span>
            {tool.label}
            {tool.soon && (
              <span class="text-[10px] bg-neutral-700 text-neutral-400 px-1.5 py-0.5 rounded-full leading-none">
                soon
              </span>
            )}
          </a>
        ))
      }
    </nav>

    <!-- Mobile menu button (simple) -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-md text-neutral-400 hover:text-neutral-100 hover:bg-neutral-800"
      aria-label="Toggle menu"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-800 px-4 py-3 flex flex-col gap-1">
    {
      tools.map((tool) => (
        <a
          href={tool.soon ? "#" : tool.href}
          class:list={[
            "flex items-center gap-2 px-3 py-2 rounded-md text-sm",
            tool.soon
              ? "text-neutral-600 cursor-default"
              : "text-neutral-300 hover:bg-neutral-800",
          ]}
        >
          <span>{tool.icon}</span>
          {tool.label}
          {tool.soon && <span class="text-xs text-neutral-600 ml-auto">soon</span>}
        </a>
      ))
    }
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
