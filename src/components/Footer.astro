---
import Icon from "../assets/images/crotools.png";
---

<footer class="border-t border-neutral-800 mt-20">
  <div class="max-w-5xl mx-auto px-4 py-8 flex flex-col sm:flex-row items-center justify-between gap-3">
    <div class="flex items-center gap-2">
      <div class="w-5 h-5 rounded bg-violet-500 flex items-center justify-center text-white text-[10px] font-bold">
        <img src={Icon.src} alt="CroTools Logo" />
      </div>
      <span class="text-sm text-neutral-500">
        cro<span class="text-violet-500">tools</span> — free micro tools
      </span>
    </div>
    <p class="text-xs text-neutral-600">
      No tracking. No account needed. Just tools.
    </p>
  </div>
</footer>
